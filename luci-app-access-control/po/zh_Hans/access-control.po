msgstr "Content-Type: text/plain; charset=UTF-8"

msgid "Access Control"
msgstr "访问控制"

msgid "Access Control allows you to manage Internet access for specific local hosts.<br/>Each rule defines when a device should be blocked from having Internet access. The rules may be active permanently or during certain times of the day.<br/>The rules may also be restricted to specific days of the week.<br/>Any device that is blocked may obtain a ticket suspending the restriction for a specified time."
msgstr "“访问控制”允许您管理局域网内特定设备的互联网访问权限。<br/>您可以对设备进行永久断网或分时段断网。<br/>规则还可以限制在每周的特定几天生效。<br/>任何被屏蔽的设备，只要点击了“临时上网”，即可临时获取一段时间的网络访问权限。"

msgid "Client Rules"
msgstr "客户端规则"

msgid "End time"
msgstr "结束时间"

msgid "General settings"
msgstr "全局设置"

msgid "Internet Access Control"
msgstr "互联网访问控制"

msgid "Issue"
msgstr "临时上网"

msgid "MAC address"
msgstr "MAC 地址"

msgid "Must be set to enable the internet access blocking"
msgstr "勾选此项以启用互联网访问拦截功能"

msgid "Start time"
msgstr "开始时间"

msgid "Ticket"
msgstr "临时上网"

msgid "Ticket time [min]"
msgstr "临时上网时长 [分钟]"

msgid "Time granted when a ticket is issued"
msgstr "点击临时上网后，设备可获得的网络访问时长"

msgid "Time value must be HH:MM or empty"
msgstr "时间格式必须是 HH:MM（如 08:30），或留空不限制"

msgid "Cancel"
msgstr "取消上网"

msgid "Enabled"
msgstr "已启用"

msgid "Name"
msgstr "名称"

msgid "Enter ticket duration (minutes):"
msgstr "请输入临时上网时长 (分钟):"

msgid "Invalid duration"
msgstr "输入时长无效"

msgid "Any day"
msgstr "任意天"
